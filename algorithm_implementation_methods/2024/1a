#include <bits/stdc++.h>
using namespace std;

#define int long long
#define pb push_back
#define st first
#define nd second
#define ll long long
const int inf=1e9+7;
const int infl=1e18+93;
vector<char> wek;

signed main()
{
    ios_base::sync_with_stdio(0);
    cin.tie(0);
    int n, wyn=0;
    cin>>n;
    for(int i=1;i<=n;i++)
    {
        char a;
        cin>>a;
        wek.pb(a);
    }
    for(int i=1;i<=n;i++)
    {
        for(int j=i;j<=n;j++)
        {
            int cnt1=0, cnt2=0;
            for(int k=i;k<=j;k++)
            {
                if(wek[k-1]=='D') cnt1--;
                else if(wek[k-1]=='U') cnt1++;
                else if(wek[k-1]=='R') cnt2++;
                else cnt2--;
            }
            //cerr<<"dla i = "<<i<<" j = "<<j<<" cnt to "<<cnt1<<" "<<cnt2<<"\n";
            if(cnt1==0&&cnt2==0)
            {
                //cerr<<"dla prze "<<i<<" "<<j<<" ";
                wyn++;
            }
        }
    }
    cout<<wyn<<"\n"; 
}
