#include <bits/stdc++.h>
using namespace std;

#define int long long
#define ll long long
#define ld long double
#define pb push_back
#define nd second
#define st first
#define sz size
#define forr(i, n) for(int i=1;i<=n;i++)
const ll infl=1e18+90;
const int inf=1e9+90;
const int roz=1e5+93;

vector<int> wek;

signed main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n, a, b, k;
    cin>>n>>a>>b>>k;
    for(int i=1;i<=n;i++)
    {
        int c;
        cin>>c;
        c%=(a+b);
        if(c==0) c+=(a+b);
        wek.pb(c);
    }
    sort(wek.begin(), wek.end());
    int wynik=0;
    for(auto it:wek)
    {
        int koszt=0;
        if(it>a)
        {
            koszt+=it/a;
            if(it%a!=0) koszt++;
            koszt--;
        }
        if(koszt<=k)
        {
            wynik++;
            k-=koszt;
        }
    }
    cout<<wynik<<"\n";
}
