#include <bits/stdc++.h>
using namespace std;

#define int long long
#define ll long long
#define ld long double
#define pb push_back
#define nd second
#define st first
#define sz size
#define forr(i, n) for(int i=1;i<=n;i++)
const ll infl=1e18+90;
const int inf=1e9+90;

signed main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int c, wynik=0;
    pair<int,int> a, b;
    cin>>c>>a.st>>b.st>>a.nd>>b.nd;
    if(a.nd<b.nd) swap(a, b);
    if(a.nd<2000&&c>2000000)
    {
        int ile=0;
        if(b.nd*a.st>b.st*a.nd)
        {
            while(c-2000*a.nd>=0)
            {
                c-=a.nd*1000;
                ile+=a.st*1000;
            }
        }
        else
        {
            while(c-2000*b.nd>=0)
            {
                c-=b.nd*1000;
                ile+=b.st*1000;
            }
        }
        if(c>4000000) cout<<"kurwa mac\n";
        for(int i=0;i<=c/a.nd;i++)
        {
            wynik=max(wynik, i*a.st+b.st*((c-i*a.nd)/b.nd));
        }
        wynik+=ile;
    }
    else
    {
        for(int i=0;i<=c/a.nd;i++)
        {
            wynik=max(wynik, i*a.st+b.st*((c-i*a.nd)/b.nd));
        }
    }
    cout<<wynik<<"\n";
}
